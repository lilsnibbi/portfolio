# Cloudflare Turnstile CAPTCHA Keys
TURNSTILE_SITE_KEY=your_cloudflare_turnstile_site_key
TURNSTILE_SECRET_KEY=your_cloudflare_turnstile_secret_key

# Discord Webhook Configuration
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# Discord OAuth Configuration (Optional for local development; mock fallback will be used if omitted)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# JWT Session Signing Key
JWT_SECRET=your_jwt_signing_secret_at_least_32_characters
